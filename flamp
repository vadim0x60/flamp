#!/bin/bash
set -o nounset -o pipefail -o errexit

# Run an Amp prompt on a Fly Machine against a given branch, then push to origin.
#
# Usage:
#   ./fly-amp.sh <branch> "your prompt here" [path-or-glob ...]
#   ./fly-amp.sh <branch> @prompt.md [path-or-glob ...]
#   ./fly-amp.sh <branch> - [path-or-glob ...]   # read prompt from stdin
#   cmd | ./fly-amp.sh <branch>                  # read prompt from stdin (bare form)
#
# Extra path/glob args are copied into the checked-out repo on the Fly Machine at
# the same relative path (e.g. logs/run.log on the client -> $HOME/work/logs/run.log
# on the server). They're added to .git/info/exclude so they won't be committed
# even if they're not in .gitignore. Globs that match nothing are silently
# skipped. Useful for shipping secrets, logs, or user data that the cloud agent
# needs but that shouldn't live in the repo.
#
# Required environment variables:
#   AMP_API_KEY        - Amp API key (from ampcode.com/settings)
#   CLOUD_SSH_KEY_PATH - Path to SSH private key with push access to the repo
#
# Optional:
#   FLY_APP           - Fly app name (default: amp-runner)
#   FLY_REGION        - Fly region (default: ord, since ampcode.com is in us-central)
#   FLY_VM_SIZE       - VM size (default: shared-cpu-2x)
#   FLY_VM_MEMORY     - VM memory in MB (default: 2048)
#   FLAMP_SIMPLEPUSH_KEY - Simplepush key.
#                          If unset, no notification is sent.

FLY_APP="${FLY_APP:-amp-runner}"
FLY_REGION="${FLY_REGION:-ord}"
FLY_VM_SIZE="${FLY_VM_SIZE:-shared-cpu-2x}"
FLY_VM_MEMORY="${FLY_VM_MEMORY:-2048}"

REMOTE_URL="$(git remote get-url origin 2>/dev/null)" || {
  echo "Error: not in a git repository or no 'origin' remote"
  exit 1
}
# Convert HTTPS URL to SSH if needed
if [[ "$REMOTE_URL" == https://github.com/* ]]; then
  REPO_URL="git@github.com:${REMOTE_URL#https://github.com/}"
else
  REPO_URL="$REMOTE_URL"
fi

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <branch> [\"prompt\" | @prompt-file.md | -] [path-or-glob ...]"
  echo "       cmd | $0 <branch> [path-or-glob ...]"
  exit 1
fi

BRANCH="$1"
shift

# Allow "HEAD" as a shorthand for the currently checked-out branch.
if [[ "$BRANCH" == "HEAD" ]]; then
  BRANCH="$(git branch --show-current)"
  if [[ -z "$BRANCH" ]]; then
    echo "Error: HEAD given but not on a branch (detached HEAD)"
    exit 1
  fi
  echo "==> Resolved HEAD to current branch: $BRANCH"
fi

# If only the branch was given and stdin is piped, read the prompt from stdin.
if [[ $# -eq 0 ]]; then
  if [[ -t 0 ]]; then
    echo "Error: no prompt given and stdin is a terminal"
    exit 1
  fi
  PROMPT="$(cat)"
  EXTRA_PATTERNS=()
else
  PROMPT_ARG="$1"
  shift
  EXTRA_PATTERNS=("$@")

  if [[ "$PROMPT_ARG" == "-" ]]; then
    if [[ -t 0 ]]; then
      echo "Error: prompt is '-' but stdin is a terminal"
      exit 1
    fi
    PROMPT="$(cat)"
  elif [[ "$PROMPT_ARG" == @* ]]; then
    PROMPT_FILE="${PROMPT_ARG#@}"
    if [[ ! -f "$PROMPT_FILE" ]]; then
      echo "Error: prompt file not found: $PROMPT_FILE"
      exit 1
    fi
    PROMPT="$(cat "$PROMPT_FILE")"
  else
    PROMPT="$PROMPT_ARG"
  fi
fi

if [[ -z "$PROMPT" ]]; then
  echo "Error: prompt is empty"
  exit 1
fi

if [[ -z "${AMP_API_KEY:-}" ]]; then
  echo "Error: AMP_API_KEY environment variable is required"
  exit 1
fi

if [[ -z "${CLOUD_SSH_KEY_PATH:-}" ]]; then
  echo "Error: CLOUD_SSH_KEY_PATH environment variable is required"
  exit 1
fi

if [[ ! -f "$CLOUD_SSH_KEY_PATH" ]]; then
  echo "Error: SSH key not found: $CLOUD_SSH_KEY_PATH"
  exit 1
fi

# Resolve to an absolute path: the fly build below runs from inside
# $BUILD_CONTEXT (see the launch step), so a relative key path would break.
SSH_KEY_PATH="$(cd "$(dirname "$CLOUD_SSH_KEY_PATH")" && pwd)/$(basename "$CLOUD_SSH_KEY_PATH")"

CLEANUP_PATHS=()
cleanup() {
  for path in "${CLEANUP_PATHS[@]}"; do
    rm -rf "$path"
  done
}
trap cleanup EXIT

DEFAULT_BRANCH="$(git remote show origin 2>/dev/null | sed -n 's/^[[:space:]]*HEAD branch: //p' || true)"
if [[ -z "$DEFAULT_BRANCH" || "$DEFAULT_BRANCH" == "(unknown)" ]]; then
  DEFAULT_BRANCH="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  DEFAULT_BRANCH="${DEFAULT_BRANCH#origin/}"
fi
if [[ -z "$DEFAULT_BRANCH" || "$DEFAULT_BRANCH" == "(unknown)" ]]; then
  echo "Error: could not determine origin's default branch"
  exit 1
fi

BUILD_CONTEXT="$(mktemp -d -t flamp-context.XXXXXX)"
CLEANUP_PATHS+=("$BUILD_CONTEXT")
echo "==> Preparing Docker build context from origin/$DEFAULT_BRANCH..."
git clone --depth=50 --branch "$DEFAULT_BRANCH" --single-branch "$REMOTE_URL" "$BUILD_CONTEXT" >/dev/null

AMP_DOCKERFILE="Dockerfile.amp"
FLAMP_DEPS="flamp-deps.Dockerfile"

if [[ -f "$AMP_DOCKERFILE" ]]; then
  # Full override: the user supplied their own Dockerfile.amp, so they own the
  # whole contract (bake the repo into /tmp/home/work including .git, install
  # project deps, install the amp CLI). flamp builds it verbatim.
  echo "==> Using existing $AMP_DOCKERFILE (full override)"
  DOCKERFILE_TO_BUILD="$AMP_DOCKERFILE"
else
  # Default path: the agent only authors a single-stage Dockerfile *fragment*
  # (its FROM + system/dependency RUN/ENV lines, ideally lifted from the repo's
  # own Dockerfile). flamp then assembles the real Dockerfile, injecting the
  # repo checkout right after FROM and the tooling/amp install at the end, so
  # the steps the runner depends on stay pinned in code rather than the agent.
  if [[ ! -f "$FLAMP_DEPS" ]]; then
    echo "==> Generating $FLAMP_DEPS (base image + dependency install)..."
    (
      cd "$BUILD_CONTEXT"
      cat <<'PROMPT_EOF' | amp -x -m smart --dangerously-allow-all
Generate a single-stage Dockerfile fragment and save it as flamp-deps.Dockerfile in the current directory. It sets up the environment needed to develop this repository.

If the repository already ships a Dockerfile (it is often production-oriented), reuse the relevant parts: the base image, system package installs, and dependency installs. Adapt them for development rather than copying blindly.

flamp builds the final image from your fragment. It injects `WORKDIR /tmp/home/work` and `COPY . /tmp/home/work` (the repository working tree, without .git) immediately after your FROM line, then appends the tooling and amp CLI install at the end. So when your dependency-install instructions run, the repository is already present at the working directory.

The fragment must:
- contain exactly one FROM line (single stage), choosing a base image suitable for development;
- install any system packages, language runtimes, and compilers the project needs (using the base image's package manager);
- install all project dependencies from the repository's setup files (pip install -r requirements*.txt, pip install -e ., npm/pnpm/yarn install, make install-deps, or the repo's documented equivalent).

The fragment must NOT include COPY of the source, WORKDIR, CMD/ENTRYPOINT, git configuration, test runs, or the amp CLI install -- flamp handles all of those.
PROMPT_EOF
    )

    if [[ ! -s "$BUILD_CONTEXT/$FLAMP_DEPS" ]]; then
      echo "Error: failed to generate $FLAMP_DEPS"
      exit 1
    fi

    cp "$BUILD_CONTEXT/$FLAMP_DEPS" "$FLAMP_DEPS"
  else
    echo "==> Using existing $FLAMP_DEPS"
  fi

  # The fragment must be single-stage so the injected checkout lands in the one
  # image the agent runs in. Reject anything else and point at the override.
  FROM_COUNT="$(grep -ciE '^[[:space:]]*from[[:space:]]' "$FLAMP_DEPS" || true)"
  if [[ "$FROM_COUNT" -ne 1 ]]; then
    echo "Error: $FLAMP_DEPS must contain exactly one FROM line (single stage); found $FROM_COUNT."
    echo "       For multi-stage or fully custom builds, provide a complete $AMP_DOCKERFILE instead."
    exit 1
  fi

  # Assemble the Dockerfile into a temp file (never written back to the repo, so
  # flamp's scaffolding always takes effect and the fragment is never mistaken
  # for a full override). Inject the checkout right after the agent's FROM...
  DOCKERFILE_TO_BUILD="$(mktemp -t flamp-dockerfile.XXXXXX)"
  CLEANUP_PATHS+=("$DOCKERFILE_TO_BUILD")
  awk '
    { print }
    !injected && toupper($1) == "FROM" {
      print ""
      print "# --- flamp: bake the default-branch worktree (no .git) into the image ---"
      print "WORKDIR /tmp/home/work"
      print "COPY . /tmp/home/work"
      print ""
      injected = 1
    }
  ' "$FLAMP_DEPS" > "$DOCKERFILE_TO_BUILD"

  # ...then append the tooling the runner needs and the amp CLI. The base image
  # is the agent's choice, so detect the package manager at build time.
  cat >> "$DOCKERFILE_TO_BUILD" <<'AMPEOF'

# --- flamp: tooling the runner needs (git/ssh for push, curl, ripgrep, git-lfs) ---
RUN (apk add --no-cache ca-certificates curl git git-lfs openssh-client ripgrep || \
     (apt-get update && apt-get install -y --no-install-recommends ca-certificates curl git git-lfs openssh-client ripgrep && rm -rf /var/lib/apt/lists/*) || \
     dnf install -y ca-certificates curl git git-lfs openssh-clients ripgrep || \
     echo "tooling not installed, skipping...") || true

# --- flamp: install amp CLI ---
RUN curl -fsSL https://ampcode.com/install.sh | bash
ENV PATH="/root/.amp/bin:${PATH}"
AMPEOF
fi

# Restore the temporary checkout, then copy in the build recipe. The build
# context should contain only origin's default branch (plus Dockerfile.amp as
# the build recipe), never the local worktree. The dependency fragment is
# inlined into Dockerfile.amp above, so it does not need to ship in the context.
git -C "$BUILD_CONTEXT" reset --hard HEAD >/dev/null
# Double-force (-ff) so nested git repos are removed too: the deps-generation
# agent runs with --dangerously-allow-all inside this dir and may create venvs,
# download data, or clone things. Plain `clean -fdx` skips dirs containing their
# own .git, which is how multi-GB junk leaks into the Docker build context.
git -C "$BUILD_CONTEXT" clean -ffdx >/dev/null

# Record the default-branch tracked files before dropping .git. The runner uses
# this list to prune files that exist on the default branch (baked into the
# image) but not on the target branch -- without a baked .git, a runtime
# checkout can't figure that out on its own.
git -C "$BUILD_CONTEXT" ls-files > "$BUILD_CONTEXT/.flamp-baked-files"

# Drop .git from the build context. A fresh clone's .git is NOT byte-stable
# (pack files differ run to run even for identical repo state), so baking it
# into `COPY . /tmp/home/work` busts the Docker layer cache on every build --
# even when nothing changed -- which then rebuilds the expensive dependency
# layers. The worktree alone IS byte-stable, so dropping .git lets the cache
# actually hit. The runner re-creates .git at runtime via git init + fetch.
rm -rf "$BUILD_CONTEXT/.git"

cp "$DOCKERFILE_TO_BUILD" "$BUILD_CONTEXT/$AMP_DOCKERFILE"

# Keep .git (defensive; already removed), the build recipe, and the
# .dockerignore itself out of the image.
cat > "$BUILD_CONTEXT/.dockerignore" <<DOCKERIGNORE_EOF
.git
/$AMP_DOCKERFILE
/.dockerignore
DOCKERIGNORE_EOF

# Collect any extra files/globs into a tarball to ship to the machine.
EXTRA_TAR=""
EXTRA_FILE_COUNT=0
if [[ ${#EXTRA_PATTERNS[@]} -gt 0 ]]; then
  shopt -s nullglob
  EXTRA_FILES=()
  for pattern in "${EXTRA_PATTERNS[@]}"; do
    # Intentional unquoted expansion so $pattern is glob-expanded; nullglob
    # makes the loop iterate zero times when nothing matches.
    for f in $pattern; do
      if [[ -e "$f" ]]; then
        EXTRA_FILES+=("$f")
      fi
    done
  done
  shopt -u nullglob

  if [[ ${#EXTRA_FILES[@]} -gt 0 ]]; then
    EXTRA_TAR="$(mktemp -t flamp-extras.XXXXXX).tar.gz"
    CLEANUP_PATHS+=("$EXTRA_TAR")
    tar -czf "$EXTRA_TAR" "${EXTRA_FILES[@]}"
    EXTRA_FILE_COUNT="${#EXTRA_FILES[@]}"
    EXTRA_TAR_BYTES="$(wc -c < "$EXTRA_TAR")"
    echo "==> Shipping $EXTRA_FILE_COUNT extra file(s) ($((EXTRA_TAR_BYTES / 1024)) KiB compressed) into the repo"
    # Files are base64-embedded into the Fly machine-create request (~33% larger).
    # Fly rejects oversized request bodies, so warn before we even try.
    if [[ "$EXTRA_TAR_BYTES" -gt 4194304 ]]; then
      echo "==> Warning: compressed extras are $((EXTRA_TAR_BYTES / 1048576)) MiB; Fly may reject the launch (\"request body too large\")."
      echo "    Consider attaching fewer files, or fetching large data inside the machine instead."
    fi
  else
    echo "==> No extra files matched, skipping"
  fi
fi

# Build the script that will run inside the Fly Machine
RUNNER_SCRIPT="$(cat <<RUNNER_EOF
#!/bin/bash
set -o nounset -o pipefail -o errexit

export HOME=/tmp/home
mkdir -p "\$HOME"

echo "==> Setting up SSH key..."
chmod 600 /ssh-key
export GIT_SSH_COMMAND="ssh -i /ssh-key -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"

echo "==> Checking out branch in baked repo..."
cd "\$HOME/work"
# The image bakes only the default-branch worktree, not .git (baking .git busts
# the Docker build cache -- see flamp). Initialize a fresh repo if needed; a
# full-override Dockerfile.amp may still bake its own .git, which we reuse.
if [[ ! -d .git ]]; then
  git init -q
fi
git remote set-url origin "$REPO_URL" 2>/dev/null || git remote add origin "$REPO_URL"
mkdir -p .git/info
{
  echo "/$AMP_DOCKERFILE"
  echo "/.dockerignore"
  echo "/.flamp-baked-files"
} >> .git/info/exclude
# If .git was baked in (full override), reset to its HEAD first.
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  git reset --hard HEAD
fi
git ls-files --error-unmatch "$AMP_DOCKERFILE" >/dev/null 2>&1 || rm -f "$AMP_DOCKERFILE"
git ls-files --error-unmatch .dockerignore >/dev/null 2>&1 || rm -f .dockerignore
if git ls-remote --exit-code --heads origin "$BRANCH" > /dev/null 2>&1; then
  git fetch --depth=50 origin "$BRANCH":"refs/remotes/origin/$BRANCH"
  TARGET_REF="origin/$BRANCH"
else
  git fetch --depth=50 origin "$DEFAULT_BRANCH":"refs/remotes/origin/$DEFAULT_BRANCH"
  TARGET_REF="origin/$DEFAULT_BRANCH"
fi
git checkout -f -B "$BRANCH" "\$TARGET_REF"
git reset --hard "\$TARGET_REF"

# Without a baked .git, the checkout above cannot prune files that exist on the
# default branch (baked into the image) but were deleted on the target branch.
# Remove any such leftovers, while preserving build-time dependency artifacts
# (node_modules, venvs, etc.) which were never tracked on the default branch.
if [[ -f .flamp-baked-files ]]; then
  while IFS= read -r baked_path; do
    [[ -z "\$baked_path" ]] && continue
    git ls-files --error-unmatch -- "\$baked_path" >/dev/null 2>&1 || rm -rf -- "\$baked_path"
  done < .flamp-baked-files
  rm -f .flamp-baked-files
fi

git config user.name "amp for Vadim Liventsev"
git config user.email "dev@vadim.me"

if [[ -f /extra-files.tar ]]; then
  echo "==> Extracting extra files into repo..."
  tar -xf /extra-files.tar -C "\$HOME/work"
  # Prevent these files from being committed even if not in .gitignore.
  mkdir -p "\$HOME/work/.git/info"
  tar -tf /extra-files.tar | while IFS= read -r path; do
    # Skip directory entries (trailing slash).
    [[ "\$path" == */ ]] && continue
    echo "/\$path" >> "\$HOME/work/.git/info/exclude"
  done
fi

echo "==> Running amp in deep mode (effort xhigh)..."
# Note: --effort only takes effect on the command that CREATES the thread (the
# root 'amp -x' form). 'amp threads continue' silently ignores --effort, so we
# must run the prompt directly here rather than pre-creating the thread with
# 'amp threads new'. We recover the thread ID from the log for the commit msg.
AMP_LOG=/tmp/amp-run.log
AMP_OUTPUT=/tmp/amp-output.txt
rm -f "\$AMP_LOG" "\$AMP_OUTPUT"
cat /prompt.txt | amp -x -m deep --effort xhigh --dangerously-allow-all --log-file "\$AMP_LOG" | tee "\$AMP_OUTPUT"
THREAD_ID="\$(grep -m1 -oE 'T-[0-9a-f-]{36}' "\$AMP_LOG")"
echo "Thread: \$THREAD_ID"

# Push amp's return message to the user's phone via Simplepush.
if [[ -n "\${FLAMP_SIMPLEPUSH_KEY:-}" ]]; then
  echo "==> Sending amp's return message to Simplepush..."
  SIMPLEPUSH_MESSAGE=/tmp/simplepush-message.txt
  if [[ ! -s "\$AMP_OUTPUT" ]]; then
    echo "(amp produced no output)" > "\$SIMPLEPUSH_MESSAGE"
  elif [[ "\$(wc -c < "\$AMP_OUTPUT")" -gt 900 ]]; then
    {
      echo "(truncated; last 900 bytes of amp output)"
      tail -c 900 "\$AMP_OUTPUT"
    } > "\$SIMPLEPUSH_MESSAGE"
  else
    cp "\$AMP_OUTPUT" "\$SIMPLEPUSH_MESSAGE"
  fi
  curl -fsSL \
    --data-urlencode "key=\$FLAMP_SIMPLEPUSH_KEY" \
    --data-urlencode "title=flamp deep on $BRANCH" \
    --data-urlencode "msg=\$(cat "\$SIMPLEPUSH_MESSAGE")" \
    https://api.simplepush.io/send > /dev/null \
    && echo "==> Sent Simplepush notification" \
    || echo "==> Warning: Simplepush notification failed"
fi

echo "==> Committing..."
git add -A
if git diff --cached --quiet; then
  echo "No changes to commit."
else
  COMMIT_MSG="amp \$THREAD_ID"
  git commit -m "\$COMMIT_MSG"

  echo "==> Pulling latest from origin/$BRANCH..."
  if git ls-remote --exit-code --heads origin "$BRANCH" > /dev/null 2>&1; then
    if ! git pull --no-edit --no-rebase origin "$BRANCH"; then
      echo "==> Merge conflicts detected, asking amp to resolve..."
      echo "Resolve all merge conflicts in this repository. After resolving, stage the resolved files with git add. Do not commit." \
        | amp -x -m rush --dangerously-allow-all
      if git diff --name-only --diff-filter=U | grep -q .; then
        echo "Error: merge conflicts remain after amp rush"
        exit 1
      fi
      git commit --no-edit
    fi
  fi

  echo "==> Pushing to origin/$BRANCH..."
  git push origin "$BRANCH"
  echo "==> Pushed to origin/$BRANCH"
fi
RUNNER_EOF
)"

echo "==> Launching Fly Machine (app=$FLY_APP, region=$FLY_REGION, branch=$BRANCH)..."
EXTRA_FILE_ARGS=()
if [[ -n "$EXTRA_TAR" ]]; then
  EXTRA_FILE_ARGS+=(--file-local "/extra-files.tar=$EXTRA_TAR")
fi

# IMPORTANT: `fly machine run` has no build-context positional (unlike
# `fly deploy`, whose first arg is the context). When building via --dockerfile
# it uses the *current working directory* as the Docker build context. So we run
# it from inside the clean checkout; otherwise fly tars up wherever the user
# invoked flamp from -- typically their repo worktree with multi-GB
# node_modules/.venv/build dirs -- and ships all of it to the builder.
(
  cd "$BUILD_CONTEXT"
  fly machine run "$BUILD_CONTEXT" bash /run-amp.sh \
    --dockerfile "$BUILD_CONTEXT/$AMP_DOCKERFILE" \
    --app "$FLY_APP" \
    --region "$FLY_REGION" \
    --vm-size "$FLY_VM_SIZE" \
    --vm-memory "$FLY_VM_MEMORY" \
    --env "AMP_API_KEY=$AMP_API_KEY" \
    --env "FLAMP_SIMPLEPUSH_KEY=${FLAMP_SIMPLEPUSH_KEY:-}" \
    --env "DEBIAN_FRONTEND=noninteractive" \
    --restart no \
    --rm \
    --file-literal /run-amp.sh="$RUNNER_SCRIPT" \
    --file-literal /prompt.txt="$PROMPT" \
    --file-local /ssh-key="$SSH_KEY_PATH" \
    ${EXTRA_FILE_ARGS[@]+"${EXTRA_FILE_ARGS[@]}"}
)

echo "==> Done."
